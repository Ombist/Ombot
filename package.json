{
  "name": "ombot",
  "version": "1.1.0",
  "description": "Ombot WebSocket relay with ED25519, NaCl box E2E, observability, and hardened operations.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "ci:quality": "npm run lint && npm run test && npm run verify-session-key",
    "security:audit": "npm audit --audit-level=high",
    "sbom": "cyclonedx-npm --output-file sbom.json --output-format json",
    "rotate:data-key": "node tools/rotate-data-key.mjs",
    "print-box-vectors": "node tools/print-box-test-vectors.mjs",
    "print-session-key-vectors": "node tools/print-session-key-vectors.mjs",
    "verify-session-key": "node tools/verify-session-key-vectors.mjs",
    "kpi:loadcheck": "node tools/e2e-ready-loadcheck.mjs"
  },
  "dependencies": {
    "prom-client": "^15.1.3",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.1.1",
    "@eslint/js": "^9.22.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "vitest": "^3.2.4"
  }
}
